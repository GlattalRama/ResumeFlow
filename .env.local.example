# ResumeFlow environment configuration
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real secrets.

# Secret used to encrypt the auth session JWT/cookie.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=replace_with_random_secret

# Public URL of the app (used by NextAuth for OAuth callbacks + secure cookies).
# Use http://localhost:3000 in development, your https URL in production.
NEXTAUTH_URL=http://localhost:3000

# Google OAuth 2.0 Web client credentials (see README "Google Cloud setup").
# If these are left as placeholders, ResumeFlow runs in LOCAL DEV MODE:
# auth is not enforced and data is stored in /data instead of Google Drive.
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
