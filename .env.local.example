# ResumeFlow environment configuration
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real secrets.

# Secret used to encrypt the auth session JWT/cookie.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=replace_with_random_secret

# Public URL of the app (used by NextAuth for OAuth callbacks + secure cookies).
# Use http://localhost:3000 in development, your https URL in production.
NEXTAUTH_URL=http://localhost:3000

# Google OAuth 2.0 Web client credentials (see README "Google Cloud setup").
# If these are left as placeholders, ResumeFlow runs in LOCAL DEV MODE:
# auth is not enforced and data is stored in /data instead of Google Drive.
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret

# Same web client ID as GOOGLE_CLIENT_ID, exposed to the client for the native
# (Capacitor) Google sign-in plugin. Client IDs are public — not a secret. Only
# needed for the mobile shell; set it in Vercel too for prod/preview builds.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace_with_google_client_id

# iOS OAuth client ID (application type "iOS", bundle ID com.resumeflowats.app,
# same Google Cloud project as the Android client). Required by the native
# Google sign-in plugin on iOS only; also public, also needed in Vercel. Its
# reversed form must be registered as a URL scheme in ios/App/App/Info.plist.
NEXT_PUBLIC_GOOGLE_IOS_CLIENT_ID=replace_with_google_ios_client_id

# --- Admin analytics (optional) ---
# Comma-separated emails allowed to open the admin analytics dashboard
# (/admin/analytics). Authorization fails closed: if unset, no signed-in user is
# an admin. In LOCAL DEV MODE (Google OAuth not configured) the dashboard is open.
ADMIN_EMAILS=

# Vercel Blob token for the durable analytics counter store. Set automatically
# when you connect a Blob store to the Vercel project. When absent, analytics
# falls back to a local JSON file (/data/analytics.json) — fine for dev, but NOT
# durable on Vercel's ephemeral filesystem. Analytics is fail-open either way.
BLOB_READ_WRITE_TOKEN=

# --- Sign in with Apple (App Store guideline 4.8) ---
# All four are required for the Apple sign-in option to appear; with any of
# them missing/placeholder the app simply offers Google only.
# Services ID (NOT the bundle id) registered in the Apple Developer portal
# with domain resumeflow-ats.com and return URL
# https://resumeflow-ats.com/api/auth/callback/apple
APPLE_CLIENT_ID=replace_with_apple_services_id
# Apple Developer Team ID (Membership page).
APPLE_TEAM_ID=replace_with_apple_team_id
# Key ID of the "Sign in with Apple" private key created in the portal.
APPLE_KEY_ID=replace_with_apple_key_id
# Contents of the downloaded .p8 key file. In Vercel, paste with literal
# newlines or as \n-escaped single line — both are handled.
APPLE_PRIVATE_KEY=replace_with_apple_private_key_p8_contents
# iOS bundle id — audience of native Sign in with Apple identity tokens.
# Defaults to com.resumeflowats.app when unset.
APPLE_BUNDLE_ID=com.resumeflowats.app
